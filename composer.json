{
    "name": "geniusdev/magento2_slack",
    "description": "Slack integration for Magento 2",
    "type": "magento2-module",
    "license": "OSL-3.0",
    "require": {
        "php": "~8.1.0 || ~8.2.0 || ~8.3.0",
        "jolicode/slack-php-api": "^4.9",
        "magento/framework": "^103.0",
        "nyholm/psr7": "^1.8",
        "symfony/http-client": "^7.4"
    },
    "suggest": {
        "league/html-to-markdown": "To convert HTML messages to Markdown"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "GeniusDev\\Slack\\": ""
        }
    }
}
